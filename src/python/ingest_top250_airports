import pandas as pd
import uuid
from datetime import datetime

from pathlib import Path
from datetime import datetime, timezone


# Setup directories
BASE_DIR = Path.cwd()
AIRPORTS_SOURCE_PATH = BASE_DIR / "data" / "source" / "top_250_airports_europe_2025.csv"
OUTPUT_FILE = BASE_DIR / "data" / "bronze" / "airport_top250_locations_raw.csv"

# New columns

run_id = str(uuid.uuid4())
loaded_at = datetime.now().replace(microsecond=0)
loaded_file_name = AIRPORTS_SOURCE_PATH.name
source_url = "https://www.flightsfrom.com/top-100-airports"


AIRPORT_COLUMNS = [
    "date",
    "airport_code",
    "flights"
]

airports_df = pd.read_csv(
    AIRPORTS_SOURCE_PATH,
    header=0,
    names=AIRPORT_COLUMNS,
)

# adding new columns
airports_df["run_id"] = run_id
airports_df["load_timestamp"] = loaded_at
airports_df["source"] = source_url



# output file
airports_df.to_csv(OUTPUT_FILE, index=False)
